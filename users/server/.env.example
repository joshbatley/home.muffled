# --- Required ---
DATABASE_URL=postgres://users2:users2@localhost:5432/users2
JWT_SECRET=dev-secret-change-me
SEED_EMAIL=admin@home.muffled
SEED_PASSWORD=admin12345

# --- Server ---
PORT=8080
LOG_LEVEL=info
# Comma-separated allowed origins; if empty, CORS is disabled (browser calls will fail)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Tokens ---
# Duration units: ms, s, m, h (no day unit — use hours, e.g. 168h = 7d)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
PASSWORD_RESET_TTL=1h
BCRYPT_COST=12

# --- Mail (optional; transactional email disabled unless host/user/password/from are all set) ---
PUBLIC_BASE_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
